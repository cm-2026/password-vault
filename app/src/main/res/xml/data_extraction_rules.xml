<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- 排除数据库文件 -->
        <exclude domain="database" path="password_vault.db" />
        <exclude domain="database" path="password_vault.db-shm" />
        <exclude domain="database" path="password_vault.db-wal" />
        
        <!-- 排除加密密钥 -->
        <exclude domain="sharedpref" path="encryption_keys.xml" />
    </cloud-backup>
    <device-transfer>
        <!-- 允许设备间传输所有数据 -->
        <include domain="database" path="password_vault.db" />
        <include domain="sharedpref" path="*" />
        <include domain="file" path="*" />
        <include domain="external" path="*" />
    </device-transfer>
</data-extraction-rules>